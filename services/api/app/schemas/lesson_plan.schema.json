{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "lesson_plan_json.v1",
  "type": "object",
  "required": ["schema_version", "user_id", "lesson_date", "human_readable_text", "theme", "objectives", "sections", "vocabulary", "quiz"],
  "properties": {
    "schema_version": { "const": "lesson_plan_json.v1" },
    "user_id": { "type": "string" },
    "lesson_date": { "type": "string" },
    "human_readable_text": { "type": "string" },
    "admin_note": { "type": ["string", "null"] },
    "admin_instruction": { "type": ["string", "null"] },
    "admin_revision_note": { "type": ["string", "null"] },
    "theme": { "type": "string" },
    "objectives": { "type": "array", "items": { "type": "string" } },
    "sections": { "type": "array" },
    "vocabulary": { "type": "array" },
    "quiz": { "type": "object" }
  }
}
