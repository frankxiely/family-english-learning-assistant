    {
      "route_item_id": "vi_phonics_001",
      "day_number": 1,
      "theme": "第一周故事：英语课开始",
      "route_module_label": "音标和音节入门",
      "main_knowledge_label": "/iː/ 和 /ɪ/",
      "passage_module_label": "上班前英语角",
      "level_code": "入门",
      "target_minutes": 30,
      "difficulty": "starter",
      "knowledge_id": "kp_phonics_intro",
      "teaching_knowledge_id": "kb_phonics_001_i_long_i_short",
      "phonics_focus": ["/iː/", "/ɪ/"],
      "new_words": ["see", "sit", "seat", "please"],
      "vocabulary": [
        {"word": "see", "phonetic": "/siː/", "part_of_speech": "verb", "part_of_speech_zh": "动词", "meaning": "看见", "needs_image": true},
        {"word": "sit", "phonetic": "/sɪt/", "part_of_speech": "verb", "part_of_speech_zh": "动词", "meaning": "坐下", "needs_image": true},
        {"word": "seat", "phonetic": "/siːt/", "part_of_speech": "noun", "part_of_speech_zh": "名词", "meaning": "座位", "needs_image": true},
        {"word": "please", "phonetic": "/pliːz/", "part_of_speech": "interjection", "part_of_speech_zh": "礼貌用语", "meaning": "请", "needs_image": false}
      ],
      "objectives": [
        "能听出 see / seat 里的 /iː/ 和 sit 里的 /ɪ/",
        "能说出 see、sit、seat、please 的核心意思",
        "能理解 Please sit here. 和 I can see it.",
        "完成听音、词义、填空和句意理解测试"
      ],
      "preview": "今天从英语角入座开始。只学 4 个词和 2 个短句：Please sit here. I can see it.",
      "knowledge_title": "今天讲什么：长短元音、4 个词、2 个短句",
      "knowledge_cards": [
        "1. 发音：/iː/ 是长音，声音拉长；see /siː/ 和 seat /siːt/ 都有这个音。",
        "2. 发音：/ɪ/ 是短音，声音短促；sit /sɪt/ 中间就是这个音，不要读成长音。",
        "3. 单词：see 是“看见”，sit 是“坐下”，seat 是“座位”，please 是礼貌地说“请”。",
        "4. 句型：Please + 动词，可以礼貌地请别人做事。Please sit here. 就是“请坐这里”。",
        "5. 句型：I can see it. 先整体记成“我能看见它”。can 表示“能”，it 指前面提到的东西。"
      ],
      "passage": {
        "title": "Please sit here",
        "passage_type": "dialogue",
        "lines": [
          {"role": "Teacher", "text": "Hi, Vi. Please sit here.", "translation": "嗨，Vi。请坐这里。"},
          {"role": "Vi", "text": "Thank you.", "translation": "谢谢。"},
          {"role": "Teacher", "text": "Can you see the screen?", "translation": "你能看见屏幕吗？"},
          {"role": "Vi", "text": "Yes, I can see it.", "translation": "可以，我能看见。"},
          {"role": "Teacher", "text": "This is your seat.", "translation": "这是你的座位。"},
          {"role": "Vi", "text": "OK. I see.", "translation": "好的。我明白了。"}
        ],
        "difficult_words": [
          {"word": "hi", "meaning": "嗨；你好"},
          {"word": "here", "meaning": "这里"},
          {"word": "thank you", "meaning": "谢谢"},
          {"word": "can", "meaning": "能；可以"},
          {"word": "screen", "meaning": "屏幕"},
          {"word": "this", "meaning": "这；这个"},
          {"word": "your", "meaning": "你的"},
          {"word": "OK", "meaning": "好的"}
        ]
      },
