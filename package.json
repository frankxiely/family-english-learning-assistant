{
  "name": "family-english-learning-assistant",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "dev": "sh scripts/dev.sh",
    "init-db": "sh scripts/init_db.sh",
    "generate-today": "sh scripts/generate_today.sh",
    "debug": "sh scripts/debug_modules.sh",
    "test:api": ".venv/bin/python -m pytest",
